# Nhập số bắt đầu
start = int(input("Nhập số bắt đầu đếm: "))

print(f"Bắt đầu đếm từ {start}...")

i = start
while True:          # Vòng lặp vô hạn
    print(i)
    i += 1           # Tăng dần 1 đơn vị
    
